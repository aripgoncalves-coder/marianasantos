
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<meta name="description" content="Assessoria Executiva para Dermatologistas — Mariana Santos. Preencha o formulário de qualificação."/>
<title>Assessoria Executiva — Mariana Santos</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Epilogue:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bege:#F7F4EE;
  --bege2:#EDE5D0;
  --gold:#C8A96E;
  --gold2:#B8922A;
  --gold3:#F5ECD7;
  --ink:#08080A;
  --ink2:#3A3830;
  --muted:#6A6460;
  --border:#E8E0CC;
  --teal:#0A7B6C;
  --green:#1A6B47;
}
html{scroll-behavior:smooth;}
body{
  font-family:'Epilogue',sans-serif;
  background:var(--bege);
  color:var(--ink);
  min-height:100vh;
}

/* NAV */
.nav{
  padding:20px 40px;
  display:flex;align-items:center;justify-content:center;
  border-bottom:1px solid var(--border);
  background:var(--bege);
}
.nav-brand{
  font-family:'Cormorant Garamond',serif;
  font-size:20px;font-weight:600;color:var(--ink);
  letter-spacing:.02em;
}
.nav-brand span{color:var(--gold2);}

/* HERO */
.hero{
  max-width:680px;margin:0 auto;
  padding:60px 24px 40px;
  text-align:center;
}
.hero-tag{
  display:inline-block;
  font-size:10px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;
  color:var(--gold2);border:1px solid var(--border);
  padding:6px 16px;border-radius:20px;margin-bottom:24px;
  background:var(--gold3);
}
.hero-title{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(32px,5vw,48px);
  line-height:1.15;color:var(--ink);
  font-weight:600;margin-bottom:16px;
}
.hero-title em{color:var(--gold2);font-style:italic;}
.hero-sub{
  font-size:16px;color:var(--muted);
  line-height:1.75;font-weight:300;
  max-width:520px;margin:0 auto 32px;
}
.hero-sub strong{color:var(--ink);font-weight:500;}

/* VALIDADOR */
.validador{
  display:flex;align-items:center;justify-content:center;
  gap:12px;margin-bottom:48px;
  padding:16px 24px;
  background:#fff;border:1px solid var(--border);
  border-radius:12px;max-width:480px;margin-left:auto;margin-right:auto;
}
.val-avatar{
  width:44px;height:44px;border-radius:50%;flex-shrink:0;
  background:var(--gold);
  display:flex;align-items:center;justify-content:center;
  font-family:'Cormorant Garamond',serif;font-size:20px;color:#fff;font-weight:600;
}
.val-text{text-align:left;}
.val-nome{font-size:13px;font-weight:600;color:var(--ink);}
.val-cred{font-size:11px;color:var(--muted);margin-top:2px;}

/* DIVIDER */
.divider{
  display:flex;align-items:center;gap:12px;
  max-width:480px;margin:0 auto 40px;
}
.div-line{flex:1;height:1px;background:var(--border);}
.div-dot{width:5px;height:5px;border-radius:50%;background:var(--gold);flex-shrink:0;}

/* FORM WRAPPER */
.form-wrap{
  max-width:580px;margin:0 auto;
  padding:0 24px 80px;
}

/* STEPS */
.step{
  background:#fff;border:1px solid var(--border);
  border-radius:16px;padding:32px;
  margin-bottom:16px;
  border-left:4px solid var(--gold);
}
.step-num{
  font-size:10px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;
  color:var(--gold2);margin-bottom:8px;
}
.step-label{
  font-family:'Cormorant Garamond',serif;
  font-size:20px;font-weight:600;color:var(--ink);
  margin-bottom:6px;line-height:1.3;
}
.step-hint{font-size:12px;color:var(--muted);margin-bottom:18px;line-height:1.5;}

/* INPUTS */
input[type="text"],
input[type="tel"],
input[type="email"],
select,
textarea{
  width:100%;
  padding:13px 16px;
  border:1px solid var(--border);
  border-radius:8px;
  font-family:'Epilogue',sans-serif;
  font-size:14px;color:var(--ink);
  background:var(--bege);
  outline:none;
  transition:border-color .2s;
  -webkit-appearance:none;
}
input:focus,select:focus,textarea:focus{
  border-color:var(--gold);
  background:#fff;
}
select{cursor:pointer;}
textarea{resize:vertical;min-height:90px;}

/* RADIO PILLS */
.radio-group{display:flex;flex-direction:column;gap:10px;}
.radio-pill{
  display:flex;align-items:center;gap:12px;
  padding:12px 16px;
  border:1px solid var(--border);border-radius:8px;
  cursor:pointer;background:var(--bege);
  transition:all .15s;
}
.radio-pill:hover{border-color:var(--gold);background:var(--gold3);}
.radio-pill input[type="radio"]{display:none;}
.radio-pill.selected{
  border-color:var(--gold);background:var(--gold3);
}
.pill-circle{
  width:18px;height:18px;border-radius:50%;
  border:2px solid var(--border);flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  transition:all .15s;
}
.radio-pill.selected .pill-circle{
  border-color:var(--gold2);background:var(--gold2);
}
.pill-check{width:6px;height:6px;border-radius:50%;background:#fff;display:none;}
.radio-pill.selected .pill-check{display:block;}
.pill-text{font-size:13px;color:var(--ink);font-weight:400;}

/* NAME ROW */
.input-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}

/* SUBMIT */
.submit-area{margin-top:32px;text-align:center;}
.submit-btn{
  width:100%;padding:16px;border-radius:10px;
  background:var(--ink);color:#fff;
  font-family:'Epilogue',sans-serif;
  font-size:14px;font-weight:600;
  border:2px solid var(--gold);
  cursor:pointer;letter-spacing:.04em;text-transform:uppercase;
  transition:all .2s;
}
.submit-btn:hover{background:var(--ink2);}
.submit-btn:disabled{opacity:.5;cursor:not-allowed;}
.submit-note{
  font-size:11px;color:var(--muted);margin-top:12px;line-height:1.6;
}
.submit-note strong{color:var(--ink);font-weight:500;}

/* AVISO PRIVACIDADE */
.privacidade{
  max-width:580px;margin:0 auto 40px;padding:0 24px;
}
.priv-box{
  background:var(--gold3);border:1px solid var(--border);
  border-radius:10px;padding:14px 18px;
  display:flex;gap:10px;align-items:flex-start;
}
.priv-icon{font-size:16px;flex-shrink:0;margin-top:1px;}
.priv-text{font-size:12px;color:var(--muted);line-height:1.65;}
.priv-text strong{color:var(--ink2);font-weight:500;}

/* ERRO */
.field-error{
  font-size:11px;color:#C23A3A;
  margin-top:5px;display:none;
}
.field-error.show{display:block;}
input.error,select.error,textarea.error{border-color:#C23A3A;}

/* SUCESSO */
.success-screen{
  display:none;
  max-width:480px;margin:0 auto;padding:60px 24px;
  text-align:center;
}
.success-screen.show{display:block;}
.success-icon{
  width:64px;height:64px;border-radius:50%;
  background:var(--gold3);border:2px solid var(--gold);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 20px;font-size:28px;
}
.success-title{
  font-family:'Cormorant Garamond',serif;
  font-size:28px;font-weight:600;color:var(--ink);
  margin-bottom:12px;
}
.success-sub{font-size:14px;color:var(--muted);line-height:1.7;margin-bottom:24px;}
.wpp-btn{
  display:inline-flex;align-items:center;gap:10px;
  padding:14px 28px;border-radius:10px;
  background:#25D366;color:#fff;
  font-family:'Epilogue',sans-serif;font-size:14px;font-weight:600;
  text-decoration:none;letter-spacing:.03em;
  transition:opacity .2s;
}
.wpp-btn:hover{opacity:.88;}
.wpp-icon{
  width:20px;height:20px;
}

@media(max-width:540px){
  .nav{padding:16px 20px;}
  .hero{padding:40px 20px 32px;}
  .form-wrap{padding:0 16px 60px;}
  .step{padding:22px;}
  .input-row{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<!-- NAV -->
<div class="nav">
  <div class="nav-brand">Mariana <span>Santos</span></div>
</div>

<!-- HERO -->
<div class="hero">
  <div class="hero-tag">Assessoria Executiva · 6 meses · Exclusivo</div>
  <h1 class="hero-title">
    Antes de conversar,<br>
    <em>quero entender o seu caso.</em>
  </h1>
  <p class="hero-sub">
    A Assessoria Executiva é <strong>exclusiva para dermatologistas com clínica própria.</strong>
    Preencha as perguntas abaixo — leva menos de 2 minutos.
    Analisarei pessoalmente e entro em contato.
  </p>

  <div class="divider">
    <div class="div-line"></div>
    <div class="div-dot"></div>
    <div class="div-line"></div>
  </div>
</div>

<!-- FORMULÁRIO -->
<div class="form-wrap" id="formSection">
  <form id="qualForm" novalidate>

    <!-- PERGUNTA 1 -->
    <div class="step">
      <div class="step-num">Pergunta 1 de 3</div>
      <div class="step-label">Qual é a sua situação atual?</div>
      <div class="step-hint">Selecione a opção que melhor descreve o seu caso.</div>
      <div class="radio-group" id="situacaoGroup">
        <label class="radio-pill" onclick="selectPill(this,'situacao','propria')">
          <input type="radio" name="situacao" value="propria"/>
          <div class="pill-circle"><div class="pill-check"></div></div>
          <span class="pill-text">Tenho clínica própria como titular</span>
        </label>
        <label class="radio-pill" onclick="selectPill(this,'situacao','socio')">
          <input type="radio" name="situacao" value="socio"/>
          <div class="pill-circle"><div class="pill-check"></div></div>
          <span class="pill-text">Sou sócio de clínica com outros médicos</span>
        </label>
        <label class="radio-pill" onclick="selectPill(this,'situacao','abrindo')">
          <input type="radio" name="situacao" value="abrindo"/>
          <div class="pill-circle"><div class="pill-check"></div></div>
          <span class="pill-text">Estou abrindo minha clínica nos próximos 6 meses</span>
        </label>
        <label class="radio-pill" onclick="selectPill(this,'situacao','outro')">
          <input type="radio" name="situacao" value="outro"/>
          <div class="pill-circle"><div class="pill-check"></div></div>
          <span class="pill-text">Outro perfil</span>
        </label>
      </div>
      <div class="field-error" id="err-situacao">Selecione uma opção para continuar.</div>
    </div>

    <!-- PERGUNTA 2 -->
    <div class="step">
      <div class="step-num">Pergunta 2 de 3</div>
      <div class="step-label">Qual é o seu principal desafio hoje?</div>
      <div class="step-hint">Seja específico — isso ajuda a entender se posso realmente ajudar.</div>
      <div class="radio-group" id="desafioGroup">
        <label class="radio-pill" onclick="selectPill(this,'desafio','agenda_lucro')">
          <input type="radio" name="desafio" value="agenda_lucro"/>
          <div class="pill-circle"><div class="pill-check"></div></div>
          <span class="pill-text">Agenda cheia mas o lucro não reflete o volume</span>
        </label>
        <label class="radio-pill" onclick="selectPill(this,'desafio','precificacao')">
          <input type="radio" name="desafio" value="precificacao"/>
          <div class="pill-circle"><div class="pill-check"></div></div>
          <span class="pill-text">Não sei se estou precificando os procedimentos corretamente</span>
        </label>
        <label class="radio-pill" onclick="selectPill(this,'desafio','numeros')">
          <input type="radio" name="desafio" value="numeros"/>
          <div class="pill-circle"><div class="pill-check"></div></div>
          <span class="pill-text">Não tenho clareza dos números reais da clínica</span>
        </label>
        <label class="radio-pill" onclick="selectPill(this,'desafio','gestao_geral')">
          <input type="radio" name="desafio" value="gestao_geral"/>
          <div class="pill-circle"><div class="pill-check"></div></div>
          <span class="pill-text">Gestão caótica — preciso de estrutura e controle</span>
        </label>
      </div>
      <div class="field-error" id="err-desafio">Selecione uma opção para continuar.</div>
    </div>

    <!-- PERGUNTA 3 -->
    <div class="step">
      <div class="step-num">Pergunta 3 de 3</div>
      <div class="step-label">Como entro em contato com você?</div>
      <div class="step-hint">Analisarei o seu caso e entro em contato em até 24h.</div>

      <div class="input-row" style="margin-bottom:12px;">
        <div>
          <input type="text" id="nome" placeholder="Seu nome completo" autocomplete="name"/>
          <div class="field-error" id="err-nome">Por favor, informe seu nome.</div>
        </div>
        <div>
          <input type="text" id="crm" placeholder="CRM (ex: CRM/SP 123456)"/>
          <div class="field-error" id="err-crm">Informe seu CRM.</div>
        </div>
      </div>

      <div style="margin-bottom:12px;">
        <input type="tel" id="whatsapp" placeholder="WhatsApp com DDD (ex: 11 99999-9999)" autocomplete="tel"/>
        <div class="field-error" id="err-whatsapp">Informe um WhatsApp válido.</div>
      </div>

      <div>
        <input type="text" id="cidade" placeholder="Cidade e estado da sua clínica (ex: São Paulo, SP)"/>
        <div class="field-error" id="err-cidade">Informe a cidade da clínica.</div>
      </div>
    </div>

    <!-- PRIVACIDADE -->
    <div class="privacidade" style="padding:0;margin-bottom:20px;">
      <div class="priv-box">
        <div class="priv-icon">🔒</div>
        <div class="priv-text">
          <strong>Seus dados são confidenciais.</strong> As informações preenchidas aqui são usadas exclusivamente para análise do seu perfil e contato da Mariana Santos. Não compartilhamos com terceiros. Aplicamos a LGPD em todas as tratativas.
        </div>
      </div>
    </div>

    <!-- SUBMIT -->
    <div class="submit-area">
      <button type="submit" class="submit-btn" id="submitBtn">
        Enviar e aguardar análise
      </button>
      <div class="submit-note">
        Após o envio você será direcionado ao WhatsApp da Mariana.<br>
        <strong>Vagas limitadas — análise feita por ordem de chegada.</strong>
      </div>
    </div>

  </form>
</div>

<!-- SUCESSO -->
<div class="success-screen" id="successScreen">
  <div class="success-icon">✦</div>
  <div class="success-title">Formulário enviado.</div>
  <div class="success-sub">
    Suas respostas foram registradas.<br>
    Agora clique abaixo para abrir o WhatsApp da Mariana —
    ela já receberá um resumo do seu perfil na mensagem.
  </div>
  <a id="wppLink" href="#" class="wpp-btn" target="_blank">
    <svg class="wpp-icon" viewBox="0 0 24 24" fill="#fff" xmlns="http://www.w3.org/2000/svg">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    Continuar pelo WhatsApp
  </a>
</div>

<script>
var selectedSituacao = '';
var selectedDesafio  = '';

function selectPill(el, group, val){
  document.querySelectorAll('[onclick*="'+group+'"]').forEach(function(p){
    p.classList.remove('selected');
  });
  el.classList.add('selected');
  if(group==='situacao') selectedSituacao = val;
  if(group==='desafio')  selectedDesafio  = val;
  var err = document.getElementById('err-'+group);
  if(err) err.classList.remove('show');
}

function showError(id, msg){
  var el = document.getElementById(id);
  if(el){ el.classList.add('show'); if(msg) el.textContent=msg; }
}
function clearError(id){
  var el = document.getElementById(id);
  if(el) el.classList.remove('show');
}
function fieldError(fieldId, errId){
  var f = document.getElementById(fieldId);
  if(f){ f.classList.add('error'); }
  showError(errId);
}
function fieldOk(fieldId, errId){
  var f = document.getElementById(fieldId);
  if(f){ f.classList.remove('error'); }
  clearError(errId);
}

var situacaoLabels = {
  'propria':  'Clínica própria como titular',
  'socio':    'Sócio de clínica',
  'abrindo':  'Abrindo clínica nos próximos 6 meses',
  'outro':    'Outro perfil'
};
var desafioLabels = {
  'agenda_lucro': 'Agenda cheia mas lucro não reflete o volume',
  'precificacao': 'Precificação de procedimentos',
  'numeros':      'Falta de clareza dos números da clínica',
  'gestao_geral': 'Gestão caótica — precisa de estrutura'
};

document.getElementById('qualForm').addEventListener('submit', function(e){
  e.preventDefault();
  var ok = true;

  if(!selectedSituacao){ showError('err-situacao'); ok=false; }
  else clearError('err-situacao');

  if(!selectedDesafio){ showError('err-desafio'); ok=false; }
  else clearError('err-desafio');

  var nome = document.getElementById('nome').value.trim();
  if(!nome){ fieldError('nome','err-nome'); ok=false; }
  else fieldOk('nome','err-nome');

  var crm = document.getElementById('crm').value.trim();
  if(!crm){ fieldError('crm','err-crm'); ok=false; }
  else fieldOk('crm','err-crm');

  var wpp = document.getElementById('whatsapp').value.trim();
  if(!wpp || wpp.replace(/\D/g,'').length < 10){
    fieldError('whatsapp','err-whatsapp'); ok=false;
  } else fieldOk('whatsapp','err-whatsapp');

  var cidade = document.getElementById('cidade').value.trim();
  if(!cidade){ fieldError('cidade','err-cidade'); ok=false; }
  else fieldOk('cidade','err-cidade');

  if(!ok) return;

  var btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.textContent = 'Preparando...';

  var msg =
    'Olá, Mariana! Preenchi o formulário de qualificação para a Assessoria Executiva.\n\n' +
    '👤 *Nome:* ' + nome + '\n' +
    '🏥 *CRM:* ' + crm + '\n' +
    '📍 *Cidade da clínica:* ' + cidade + '\n' +
    '📱 *WhatsApp:* ' + wpp + '\n\n' +
    '📋 *Situação atual:* ' + (situacaoLabels[selectedSituacao]||selectedSituacao) + '\n' +
    '⚡ *Principal desafio:* ' + (desafioLabels[selectedDesafio]||selectedDesafio) + '\n\n' +
    'Aguardo sua análise. Obrigado(a)!';

  var numero = '5516992399156';
  var wppUrl = 'https://wa.me/' + numero + '?text=' + encodeURIComponent(msg);

  document.getElementById('wppLink').href = wppUrl;
  document.getElementById('formSection').style.display = 'none';
  document.querySelector('.hero').style.display = 'none';
  document.getElementById('successScreen').classList.add('show');
  window.scrollTo({top:0, behavior:'smooth'});

  setTimeout(function(){
    window.open(wppUrl, '_blank');
  }, 800);
});
</script>
</body>
</html>
